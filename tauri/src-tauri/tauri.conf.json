{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dumb Chat",
  "version": "1.0.1",

  "identifier": "com.dumbchat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Dumb Chat",
        "width": 800,
        "height": 600
      }

    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "category": "SocialNetworking",
    "icon": ["icons/icon.icns"]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/trevadelman/dumb-chat/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4QjQ0NDQzRkExQTYyNEEKUldSS1locjZRMFMwZUZSekJlbktqNGVrTDMzVExwRktkNG92Tms0dGtWVkZuNDdaR29NVnZkdWcK"
    }
  }
}
